PORT=5000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# JWT Settings (change SECRET_KEY in production)
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Container Manager Service
CONTAINER_SERVICE_URL=http://localhost:5001

# AI Agent Service
AI_AGENT_SERVICE_URL=http://localhost:5002

# Tunnel Manager Service
TUNNEL_SERVICE_URL=http://localhost:5003

# Database
DATABASE_PATH=./data/ghost-labs.db
